# ============================================================
# RPI Helm Values — Generated by Terraform
# Do not edit manually. Re-run `terraform apply` to regenerate.
# ============================================================

global:
  deployment:
    platform: azure
    images:
      tag: "${rpi_image_tag}"

# ----------------------------------------------------------
# Operational Database (Azure SQL)
# ----------------------------------------------------------
databases:
  operational:
    provider: sqlserver
    server_host: "${sql_server_fqdn}"
    server_username: "${sql_admin_username}"
    server_password: "${sql_admin_password}"
    pulse_database_name: "${pulse_database_name}"
    pulse_logging_database_name: "${pulse_logging_database_name}"
    encrypt: true

# ----------------------------------------------------------
# Cloud Identity (Azure Workload Identity)
# ----------------------------------------------------------
cloudIdentity:
  enabled: true
  serviceAccount:
    create: true
    name: redpoint-rpi
  azure:
    managedIdentityClientId: "${managed_identity_client_id}"
    tenantId: "${tenant_id}"

# ----------------------------------------------------------
# Secrets Management
# ----------------------------------------------------------
secretsManagement:
  provider: "${secrets_provider}"
%{ if secrets_provider == "sdk" ~}
  sdk:
    azure:
      vaultUri: "${keyvault_uri}"
      configurationReloadIntervalSeconds: 30
      useADTokenForDatabaseConnection: true
%{ endif ~}
%{ if secrets_provider == "csi" ~}
  csi:
    secretName: redpoint-rpi-secrets
%{ endif ~}
%{ if secrets_provider == "kubernetes" ~}
  kubernetes:
    autoCreateSecrets: true
    secretName: redpoint-rpi-secrets
%{ endif ~}

# ----------------------------------------------------------
# Ingress
# ----------------------------------------------------------
ingress:
  controller:
    enabled: true
  domain: "${ingress_domain}"
  hosts:
    config: rpi-deploymentapi
    client: rpi-interactionapi
    integration: rpi-integrationapi
    realtime: rpi-realtimeapi
    callbackapi: rpi-callbackapi
    queuereader: rpi-queuereader
    rabbitmqconsole: rpi-rabbitmq-console
    smartactivation: rpi-smartActivation
    # helmcopilot: rpi-helmcopilot

# ----------------------------------------------------------
# Optional Features
# Uncomment to enable. See docs/readme-configuration.md
# ----------------------------------------------------------
# helmcopilot:
#   enabled: true
# databaseUpgrade:
#   enabled: true
# preflight:
#   enabled: true
#   mode: test
