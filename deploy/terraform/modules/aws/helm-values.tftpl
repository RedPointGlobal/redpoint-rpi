# ============================================================
# RPI Helm Values — Generated by Terraform
# Do not edit manually; re-run 'terraform apply' to regenerate.
# ============================================================

global:
  deployment:
    platform: amazon
    images:
      tag: "${rpi_image_tag}"

# ----------------------------------------------------------
# Operational Database (Amazon RDS)
# ----------------------------------------------------------
databases:
  operational:
    provider: sqlserver
    server_host: "${rds_endpoint}"
    server_username: "${rds_admin_username}"
    server_password: "${rds_admin_password}"
    pulse_database_name: Pulse
    pulse_logging_database_name: PulseLogging
    encrypt: true

# ----------------------------------------------------------
# Cloud Identity (IRSA)
# ----------------------------------------------------------
cloudIdentity:
  enabled: true
  serviceAccount:
    create: true
    name: redpoint-rpi
  amazon:
    roleArn: "${irsa_role_arn}"
    region: "${region}"

# ----------------------------------------------------------
# Secrets Management
# ----------------------------------------------------------
secretsManagement:
  provider: "${secrets_provider}"
%{ if secrets_provider == "sdk" ~}
  sdk:
    amazon:
      secretTagKey: "redpoint:application"
%{ endif ~}

# ----------------------------------------------------------
# Ingress
# ----------------------------------------------------------
ingress:
  domain: "${ingress_domain}"

# ----------------------------------------------------------
# Realtime API
# ----------------------------------------------------------
realtimeapi:
  queueProvider:
    provider: amazonsqs
    amazonsqs:
      credentialsType: accessKey

# ----------------------------------------------------------
# Optional Features
# Uncomment to enable. See docs/readme-configuration.md
# ----------------------------------------------------------
# helmcopilot:
#   enabled: true
# databaseUpgrade:
#   enabled: true
# preflight:
#   enabled: true
#   mode: test
