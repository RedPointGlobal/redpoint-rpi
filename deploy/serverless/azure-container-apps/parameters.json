{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "eastus"
    },
    "imageTag": {
      "value": "7.7.20260327.1408"
    },
    "imageRegistry": {
      "value": "rg1acrpub.azurecr.io/docker/redpointglobal/releases"
    },
    "databaseType": {
      "value": "sqlserver"
    },
    "databaseUsername": {
      "value": "<your-db-admin-username>"
    },
    "databasePassword": {
      "value": "<your-db-admin-password>"
    },
    "useExistingDatabase": {
      "value": false
    },
    "existingDatabaseServerFQDN": {
      "value": ""
    },
    "existingPulseDatabaseName": {
      "value": "Pulse"
    },
    "existingPulseLoggingDatabaseName": {
      "value": "Pulse_Logging"
    },
    "ingressDomain": {
      "value": ""
    },
    "ingressMode": {
      "value": "external"
    },
    "enableRealtime": {
      "value": false
    },
    "enableCallback": {
      "value": false
    },
    "enableQueueReader": {
      "value": false
    },
    "cacheProvider": {
      "value": "redis"
    },
    "cacheProviderType": {
      "value": "managed"
    },
    "queueProvider": {
      "value": "servicebus"
    },
    "queueProviderType": {
      "value": "managed"
    },
    "useExistingVnet": {
      "value": false
    },
    "enablePrivateEndpoints": {
      "value": false
    }
  }
}
